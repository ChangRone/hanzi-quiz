{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PackSchemaV1",
  "type": "object",
  "required": ["id", "title", "year", "publisherCode", "grade", "semester", "version", "questions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[0-9]{8}$" },
    "title": { "type": "string", "minLength": 1 },
    "year": { "type": "string", "pattern": "^[0-9]{4}$" },
    "publisherCode": { "type": "string", "pattern": "^[0-9]$" },
    "grade": { "type": "string", "pattern": "^[0-9]{2}$" },
    "semester": { "type": "string", "pattern": "^[0-9]$" },
    "version": { "type": "string", "minLength": 1 },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question" }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["id", "examPhase", "readText", "tokens"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9]{12}$" },
        "examPhase": { "type": "string", "enum": ["midterm_before", "midterm_after", "final_before"] },
        "readText": { "type": "string", "minLength": 1 },
        "tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/token" }
        }
      }
    },
    "token": {
      "type": "object",
      "required": ["type", "char", "zhuyin"],
      "properties": {
        "type": { "type": "string", "enum": ["text", "blank"] },
        "char": { "type": "string", "minLength": 1, "maxLength": 1 },
        "zhuyin": { "type": "string" }
      }
    }
  }
}
